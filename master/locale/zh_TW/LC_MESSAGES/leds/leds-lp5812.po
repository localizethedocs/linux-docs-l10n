#: ../../../leds/leds-lp5812.rst:5
msgid "Kernel driver for lp5812"
msgstr ""

#: ../../../leds/leds-lp5812.rst:7
msgid "TI/National Semiconductor LP5812 LED Driver"
msgstr ""

#: ../../../leds/leds-lp5812.rst:8
msgid "Datasheet: https://www.ti.com/product/LP5812#tech-docs"
msgstr ""

#: ../../../leds/leds-lp5812.rst:10
msgid "Authors: Jared Zhou <jared-zhou@ti.com>"
msgstr ""

#: ../../../leds/leds-lp5812.rst:13
msgid "Description"
msgstr ""

#: ../../../leds/leds-lp5812.rst:15
msgid ""
"The LP5812 is a 4x3 matrix LED driver with support for both manual and "
"autonomous animation control. This driver provides sysfs interfaces to "
"control and configure the LP5812 device and its LED channels."
msgstr ""

#: ../../../leds/leds-lp5812.rst:20
msgid "Sysfs Interface"
msgstr ""

#: ../../../leds/leds-lp5812.rst:22
msgid ""
"This driver uses the standard multicolor LED class interfaces defined in "
"Documentation/ABI/testing/sysfs-class-led-multicolor.rst."
msgstr ""

#: ../../../leds/leds-lp5812.rst:25
msgid ""
"Each LP5812 LED output appears under ``/sys/class/leds/`` with its assigned "
"label (for example ``LED_A``)."
msgstr ""

#: ../../../leds/leds-lp5812.rst:28
msgid "The following attributes are exposed:"
msgstr ""

#: ../../../leds/leds-lp5812.rst:29
msgid "multi_intensity: Per-channel RGB intensity control"
msgstr ""

#: ../../../leds/leds-lp5812.rst:30
msgid "brightness: Standard brightness control (0-255)"
msgstr ""

#: ../../../leds/leds-lp5812.rst:33
msgid "Autonomous Control Modes"
msgstr ""

#: ../../../leds/leds-lp5812.rst:35
msgid ""
"The driver also supports autonomous control through pattern configuration (e."
"g., direct, tcmscan, or mixscan modes) defined in the device tree. When "
"configured, the LP5812 can generate transitions and color effects without "
"CPU intervention."
msgstr ""

#: ../../../leds/leds-lp5812.rst:40
msgid ""
"Refer to the device tree binding document for valid mode strings and "
"configuration examples."
msgstr ""

#: ../../../leds/leds-lp5812.rst:44
msgid "Example Usage"
msgstr ""

#: ../../../leds/leds-lp5812.rst:46
msgid "To control LED_A::"
msgstr ""

#: ../../../leds/leds-lp5812.rst:47
msgid ""
"# Set RGB intensity (R=50, G=50, B=50) echo 50 50 50 > /sys/class/leds/LED_A/"
"multi_intensity # Set overall brightness to maximum echo 255 > /sys/class/"
"leds/LED_A/brightness"
msgstr ""
