#: ../../../networking/kapi:125: ../include/linux/phy.h:1025
msgid "Capabilities of Mean Square Error (MSE) measurement interface"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1053
msgid "``max_average_mse``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1054
msgid ""
"The maximum value for an average MSE snapshot. This defines the scale for "
"the measurement. If the PHY_MSE_CAP_AVG capability is supported, this value "
"MUST be greater than 0. (vendor-specific units)."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1056
msgid "``max_peak_mse``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1057
msgid ""
"The maximum value for a peak MSE snapshot. If either PHY_MSE_CAP_PEAK or "
"PHY_MSE_CAP_WORST_PEAK is supported, this value MUST be greater than 0. "
"(vendor-specific units)."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1059
msgid "``refresh_rate_ps``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1060
msgid ""
"The typical interval, in picoseconds, between hardware updates of the MSE "
"values. This is an estimate, and callers should not assume synchronous "
"sampling. (vendor-specific units)."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1062
msgid "``num_symbols``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1063
msgid ""
"The number of symbols aggregated per hardware sample to calculate the MSE. "
"(vendor-specific units)."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1064
msgid "``supported_caps``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1065
msgid ""
"A bitmask of PHY_MSE_CAP_* values indicating which measurement types (e.g., "
"average, peak) and channels (e.g., per-pair or link-wide) are supported."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1026
msgid "Standardization notes:"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1028
msgid ""
"Presence of MSE/SQI/pMSE is defined by OPEN Alliance specs, but numeric "
"scaling, refresh/update rate and aggregation windows are not fixed and are "
"vendor-/product-specific. (OA 100BASE-T1 TC1 v1.0 6.1.*; OA 1000BASE-T1 TC12 "
"v2.2 6.1.*)"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1033
msgid ""
"Typical recommendations: 2^16 symbols and 0..511 scaling for MSE; pMSE only "
"defined for 100BASE-T1 (sliding window example), others are vendor "
"extensions. Drivers must report actual scale/limits here."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1037
msgid ""
"Describes the MSE measurement capabilities for the current link mode. These "
"properties are dynamic and may change when link settings are modified. "
"Callers should re-query this capability after any link state change to "
"ensure they have the most up-to-date information."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1042
msgid ""
"Callers should only request measurements for channels and types that are "
"indicated as supported by the **supported_caps** bitmask. If "
"**supported_caps** is 0, the device provides no MSE diagnostics, and driver "
"operations should typically return -EOPNOTSUPP."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1047
msgid ""
"Snapshot values for average and peak MSE can be normalized to a 0..1 ratio "
"by dividing the raw snapshot by the corresponding **max_average_mse** or "
"**max_peak_mse** value."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1077
msgid "A snapshot of Mean Square Error (MSE) diagnostics"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1085
msgid "``average_mse``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1086
msgid ""
"The average MSE value over the measurement window. OPEN Alliance references "
"MSE as a DCQ metric; recommends 2^16 symbols and 0..511 scaling. Exact scale "
"and refresh are vendor-specific. (100BASE-T1 TC1 v1.0 6.1.1; 1000BASE-T1 "
"TC12 v2.2 6.1.1)."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1090
msgid "``peak_mse``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1091
msgid ""
"The peak MSE value observed within the measurement window. For 100BASE-T1, "
"\"pMSE\" is optional and may be implemented via a sliding 128-symbol window "
"with periodic capture; not standardized for 1000BASE-T1. (100BASE-T1 TC1 "
"v1.0 6.1.3, Table \"DCQ.peakMSE\")."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1095
msgid "``worst_peak_mse``"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1096
msgid ""
"A latched high-water mark of the peak MSE since last read (read-to-clear if "
"implemented). OPEN Alliance shows a latched \"worst case peak MSE\" for "
"100BASE-T1 pMSE; availability/semantics outside that are vendor-specific. "
"(100BASE-T1 TC1 v1.0 6.1.3, DCQ.peakMSE high byte; 1000BASE-T1 TC12 v2.2 "
"treats DCQ details as vendor-specific.)"
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1078
msgid ""
"Holds a set of MSE diagnostic values that were all captured from a single "
"measurement window."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1081
msgid ""
"Values are raw, device-scaled and not normalized. Use struct "
"phy_mse_capability to interpret the scale and sampling window."
msgstr ""

#: ../../../networking/kapi:125: ../include/linux/phy.h:1108
msgid "Driver structure for a particular PHY type"
msgstr ""

