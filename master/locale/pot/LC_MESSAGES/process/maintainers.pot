#: ../../../../MAINTAINERS:4
msgid "List of maintainers"
msgstr ""

#: ../../../../MAINTAINERS:7
msgid "Descriptions of section entries and preferred order"
msgstr ""

#: ../../../../MAINTAINERS:9
msgid "M: *Mail* patches to: FullName <address@domain>"
msgstr ""

#: ../../../../MAINTAINERS:10
msgid "R: Designated *Reviewer*: FullName <address@domain>"
msgstr ""

#: ../../../../MAINTAINERS:11
msgid "These reviewers should be CCed on patches."
msgstr ""

#: ../../../../MAINTAINERS:12
msgid "L: *Mailing list* that is relevant to this area"
msgstr ""

#: ../../../../MAINTAINERS:13
msgid "S: *Status*, one of the following:"
msgstr ""

#: ../../../../MAINTAINERS:14
msgid "Supported:   Someone is actually paid to look after this."
msgstr ""

#: ../../../../MAINTAINERS:15
msgid "Maintained:  Someone actually looks after it."
msgstr ""

#: ../../../../MAINTAINERS:16
msgid "Odd Fixes:   It has a maintainer but they don't have time to do"
msgstr ""

#: ../../../../MAINTAINERS:17
msgid "much other than throw the odd patch in. See below.."
msgstr ""

#: ../../../../MAINTAINERS:18
msgid "Orphan:      No current maintainer [but maybe you could take the"
msgstr ""

#: ../../../../MAINTAINERS:19
msgid "role as you write your new code]."
msgstr ""

#: ../../../../MAINTAINERS:20
msgid "Obsolete:    Old code. Something tagged obsolete generally means"
msgstr ""

#: ../../../../MAINTAINERS:21
msgid "it has been replaced by a better system and you"
msgstr ""

#: ../../../../MAINTAINERS:22
msgid "should be using that."
msgstr ""

#: ../../../../MAINTAINERS:23
msgid "W: *Web-page* with status/info"
msgstr ""

#: ../../../../MAINTAINERS:24
msgid "Q: *Patchwork* web based patch tracking system site"
msgstr ""

#: ../../../../MAINTAINERS:25
msgid "B: URI for where to file *bugs*. A web-page with detailed bug"
msgstr ""

#: ../../../../MAINTAINERS:26
msgid "filing info, a direct bug tracker link, or a mailto: URI."
msgstr ""

#: ../../../../MAINTAINERS:27
msgid "C: URI for *chat* protocol, server and channel where developers"
msgstr ""

#: ../../../../MAINTAINERS:28
msgid "usually hang out, for example irc://server/channel."
msgstr ""

#: ../../../../MAINTAINERS:29
msgid "P: *Subsystem Profile* document for more details submitting"
msgstr ""

#: ../../../../MAINTAINERS:30
msgid "patches to the given subsystem. This is either an in-tree file,"
msgstr ""

#: ../../../../MAINTAINERS:31
msgid ""
"or a URI. See :doc:`maintainer/maintainer-entry-profile <../maintainer/"
"maintainer-entry-profile>`"
msgstr ""

#: ../../../../MAINTAINERS:32
msgid "for details."
msgstr ""

#: ../../../../MAINTAINERS:33
msgid "T: *SCM* tree type and location."
msgstr ""

#: ../../../../MAINTAINERS:34
msgid "Type is one of: git, hg, quilt, stgit, topgit"
msgstr ""

#: ../../../../MAINTAINERS:35
msgid "F: *Files* and directories wildcard patterns."
msgstr ""

#: ../../../../MAINTAINERS:36
msgid "A trailing slash includes all files and subdirectory files."
msgstr ""

#: ../../../../MAINTAINERS:37
msgid "F:   drivers/net/    all files in and below drivers/net"
msgstr ""

#: ../../../../MAINTAINERS:38
msgid "F:   drivers/net/*   all files in drivers/net, but not below"
msgstr ""

#: ../../../../MAINTAINERS:39
msgid "F:   */net/*         all files in \"any top level directory\"/net"
msgstr ""

#: ../../../../MAINTAINERS:40
msgid "F:   fs/**/*foo*.c   all *foo*.c files in any subdirectory of fs"
msgstr ""

#: ../../../../MAINTAINERS:41
msgid "One pattern per line.  Multiple F: lines acceptable."
msgstr ""

#: ../../../../MAINTAINERS:42
msgid "X: *Excluded* files and directories that are NOT maintained, same"
msgstr ""

#: ../../../../MAINTAINERS:43
msgid "rules as F:. Files exclusions are tested before file matches."
msgstr ""

#: ../../../../MAINTAINERS:44
msgid "Can be useful for excluding a specific subdirectory, for instance:"
msgstr ""

#: ../../../../MAINTAINERS:45
msgid "F:   net/"
msgstr ""

#: ../../../../MAINTAINERS:46
msgid "X:   net/ipv6/"
msgstr ""

#: ../../../../MAINTAINERS:47
msgid "matches all files in and below net excluding net/ipv6/"
msgstr ""

#: ../../../../MAINTAINERS:48
msgid "N: Files and directories *Regex* patterns."
msgstr ""

#: ../../../../MAINTAINERS:49
msgid "N:   [^a-z]tegra     all files whose path contains tegra"
msgstr ""

#: ../../../../MAINTAINERS:50
msgid "(not including files like integrator)"
msgstr ""

#: ../../../../MAINTAINERS:51
msgid "One pattern per line.  Multiple N: lines acceptable."
msgstr ""

#: ../../../../MAINTAINERS:52
msgid "scripts/get_maintainer.pl has different behavior for files that"
msgstr ""

#: ../../../../MAINTAINERS:53
msgid "match F: pattern and matches of N: patterns.  By default,"
msgstr ""

#: ../../../../MAINTAINERS:54
msgid "get_maintainer will not look at git log history when an F: pattern"
msgstr ""

#: ../../../../MAINTAINERS:55
msgid "match occurs.  When an N: match occurs, git log history is used"
msgstr ""

#: ../../../../MAINTAINERS:56
msgid "to also notify the people that have git commit signatures."
msgstr ""

#: ../../../../MAINTAINERS:57
msgid "K: *Content regex* (perl extended) pattern match in a patch or file."
msgstr ""

#: ../../../../MAINTAINERS:58
msgid "For instance:"
msgstr ""

#: ../../../../MAINTAINERS:59
msgid "K: of_get_profile"
msgstr ""

#: ../../../../MAINTAINERS:60
msgid "matches patches or files that contain \"of_get_profile\""
msgstr ""

#: ../../../../MAINTAINERS:61
msgid "K: \\\\b(printk|pr_(info|err))\\\\b"
msgstr ""

#: ../../../../MAINTAINERS:62
msgid "matches patches or files that contain one or more of the words"
msgstr ""

#: ../../../../MAINTAINERS:63
msgid "printk, pr_info or pr_err"
msgstr ""

#: ../../../../MAINTAINERS:64
msgid "One regex pattern per line.  Multiple K: lines acceptable."
msgstr ""

#: ../../../../MAINTAINERS:68
msgid "Maintainers List"
msgstr ""

#: ../../../../MAINTAINERS:70
msgid ""
"When reading this list, please look for the most precise areas first. When "
"adding to this list, please keep the entries in alphabetical order."
msgstr ""

