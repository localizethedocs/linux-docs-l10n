#: ../../../iio/ad4030.rst:44
msgid "Labels"
msgstr ""

#: ../../../iio/ad4030.rst:46
msgid ""
"For ease of use, the IIO channels provide a label. For a differential "
"channel, the label is ``differentialN`` where ``N`` is the \"hardware\" "
"channel id. For a common-mode channel, the label is ``common-modeN`` where "
"``N`` is the \"hardware\" channel id."
msgstr ""

#: ../../../iio/ad4030.rst:51
msgid "The possible labels are:"
msgstr ""

#: ../../../iio/ad4030.rst:56
