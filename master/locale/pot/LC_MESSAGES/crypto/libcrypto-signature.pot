msgid "``const u8 *pk``"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:36
msgid "The public key"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:38
msgid "``size_t pk_len``"
msgstr ""

