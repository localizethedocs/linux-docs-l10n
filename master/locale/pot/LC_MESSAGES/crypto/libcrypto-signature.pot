#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:41
msgid "**Description**"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:40
msgid ""
"This verifies a signature using pure ML-DSA with the specified parameter "
"set. The context string is assumed to be empty.  This corresponds to FIPS "
"204 Algorithm 3 \"ML-DSA.Verify\" with the ctx parameter set to the empty "
"string and the lengths of the signature and key given explicitly by the "
"caller."
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:45
msgid "**Context**"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:46
msgid "Might sleep"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:48
msgid "**Return**"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:48
msgid "0 if the signature is valid"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:49
msgid "-EBADMSG if the signature and/or public key is malformed"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:50
msgid "-EKEYREJECTED if the signature is invalid but otherwise well-formed"
msgstr ""

#: ../../../crypto/libcrypto-signature:11: ../include/crypto/mldsa.h:51
msgid "-ENOMEM if out of memory so the validity of the signature is unknown"
msgstr ""
