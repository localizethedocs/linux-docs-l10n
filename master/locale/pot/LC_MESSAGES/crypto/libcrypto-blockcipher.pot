msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:73
msgid "An AES key prepared for encryption"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:77
#: ../include/crypto/aes.h:109
msgid "**Definition**::"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:86
#: ../include/crypto/aes.h:116
msgid "**Members**"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:74
msgid "``len``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:75
msgid "Key length in bytes: 16 for AES-128, 24 for AES-192, 32 for AES-256."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:75
msgid "``nrounds``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:76
msgid ""
"Number of rounds: 10 for AES-128, 12 for AES-192, 14 for AES-256. This is '6 "
"+ **len** / 4' and is cached so that AES implementations that need it don't "
"have to recompute it for each en/decryption."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:78
msgid "``padding``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:79
msgid ""
"Padding to make offsetof(**k**) be a multiple of 16, so that aligning this "
"struct to a 16-byte boundary results in **k** also being 16-byte aligned.  "
"Users aren't required to align this struct to 16 bytes, but it may slightly "
"improve performance."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:82
msgid "``k``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:83
msgid ""
"This typically contains the AES round keys as an array of '**nrounds** + 1' "
"groups of four u32 words.  However, architecture-specific implementations of "
"AES may store something else here, e.g. just the raw key if it's all they "
"need."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:89
#: ../include/crypto/aes.h:151 ../include/crypto/aes.h:319
#: ../include/crypto/aes.h:344
msgid "**Description**"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:86
msgid ""
"Note that this struct is about half the size of struct aes_key.  This is "
"separate from struct aes_key so that modes that need only AES encryption (e."
"g. AES-GCM, AES-CTR, AES-CMAC, tweak key in AES-XTS) don't incur the time "
"and space overhead of computing and caching the decryption round keys."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:91
msgid ""
"Note that there's no decryption-only equivalent (i.e. \"struct "
"aes_deckey\"), since (a) it's rare that modes need decryption-only, and (b) "
"some AES implementations use the same **k** for both encryption and "
"decryption, either always or conditionally; in the latter case both **k** "
"and **inv_k** are needed."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:105
msgid "An AES key prepared for encryption and decryption"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:106
msgid "``aes_enckey``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:107
msgid "Common fields and the key prepared for encryption"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:107
msgid "``inv_k``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:108
msgid ""
"This generally contains the round keys for the AES Equivalent Inverse "
"Cipher, as an array of '**nrounds** + 1' groups of four u32 words.  However, "
"architecture-specific implementations of AES may store something else here.  "
"For example, they may leave this field uninitialized if they use **k** for "
"both encryption and decryption."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:146
msgid "Expands the AES key as described in FIPS-197"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:150
#: ../include/crypto/aes.h:317 ../include/crypto/aes.h:342
#: ../include/crypto/aes.h:373 ../include/crypto/aes.h:385
#: ../../../crypto/libcrypto-blockcipher:19: ../include/crypto/des.h:38
#: ../include/crypto/des.h:49
msgid "**Parameters**"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:152
msgid "``struct crypto_aes_ctx *ctx``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:147
msgid "The location where the computed key will be stored."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:149
#: ../include/crypto/aes.h:316 ../include/crypto/aes.h:341
msgid "``const u8 *in_key``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:148
msgid "The supplied key."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:150
msgid "``unsigned int key_len``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:149
msgid "The length of the supplied key."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:150
msgid ""
"Returns 0 on success. The function fails only if an invalid key size (or "
"pointer) is supplied. The expanded key size is 240 bytes (max of 14 rounds "
"with a unique 16 bytes key schedule plus a 16 bytes key which is used before "
"the first round). The decryption key is prepared for the \"Equivalent "
"Inverse Cipher\" as described in FIPS-197. The first slot (16 bytes) of each "
"key (enc or dec) is for the initial combination, the second slot for the "
"first round and so on."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:313
msgid "Prepare an AES key for encryption and decryption"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:319
msgid "``struct aes_key *key``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:314
#: ../include/crypto/aes.h:339
msgid "(output) The key structure to initialize"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:315
#: ../include/crypto/aes.h:340
msgid "The raw AES key"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:317
#: ../include/crypto/aes.h:342
msgid "``size_t key_len``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:316
#: ../include/crypto/aes.h:341
msgid ""
"Length of the raw key in bytes.  Should be either AES_KEYSIZE_128, "
"AES_KEYSIZE_192, or AES_KEYSIZE_256."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:318
msgid ""
"This prepares an AES key for both the encryption and decryption directions "
"of the block cipher.  Typically this involves expanding the raw key into "
"both the standard round keys and the Equivalent Inverse Cipher round keys, "
"but some architecture-specific implementations don't do the full expansion "
"here."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:323
msgid ""
"The caller is responsible for zeroizing both the struct aes_key and the raw "
"key once they are no longer needed."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:326
msgid "If you don't need decryption support, use aes_prepareenckey() instead."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:328
#: ../include/crypto/aes.h:354 ../../../crypto/libcrypto-blockcipher:19:
#: ../include/crypto/des.h:39 ../include/crypto/des.h:50
msgid "**Return**"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:329
#: ../include/crypto/aes.h:355
msgid ""
"0 on success or -EINVAL if the given key length is invalid.  No other errors "
"are possible, so callers that always pass a valid key length don't need to "
"check for errors."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:333
#: ../include/crypto/aes.h:359 ../include/crypto/aes.h:375
#: ../include/crypto/aes.h:386
msgid "**Context**"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:333
#: ../include/crypto/aes.h:359 ../include/crypto/aes.h:375
#: ../include/crypto/aes.h:386
msgid "Any context."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:338
msgid "Prepare an AES key for encryption-only"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:344
msgid "``struct aes_enckey *key``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:343
msgid ""
"This prepares an AES key for only the encryption direction of the block "
"cipher.  Typically this involves expanding the raw key into only the "
"standard round keys, resulting in a struct about half the size of struct "
"aes_key."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:347
msgid ""
"The caller is responsible for zeroizing both the struct aes_enckey and the "
"raw key once they are no longer needed."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:350
msgid ""
"Note that while the resulting prepared key supports only AES encryption, it "
"can still be used for decrypting in a mode of operation that uses AES in "
"only the encryption (forward) direction, for example counter mode."
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:369
msgid "Encrypt a single AES block"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:375
msgid "``aes_encrypt_arg key``"
msgstr ""

#: ../../../crypto/libcrypto-blockcipher:11: ../include/crypto/aes.h:370
msgid ""
"The AES key, as a pointer to either an encryption-only key (struct "
"aes_enckey) or a full, bidirectional key (struct aes_key)."
msgstr ""

