#: ../../../userspace-api/media/v4l/subdev-formats.rst:39
msgid "``colorspace``"
msgstr ""

#: ../../../userspace-api/media/v4l/subdev-formats.rst:40
msgid ""
"Image colorspace, from enum :c:type:`v4l2_colorspace`. Must be set by the "
"driver for subdevices. If the application sets the flag "
"``V4L2_MBUS_FRAMEFMT_SET_CSC`` then the application can set this field on "
"the source pad to request a specific colorspace for the media bus data. If "
"the driver cannot handle the requested conversion, it will return another "
"supported colorspace. The driver indicates that colorspace conversion is "
"supported by setting the flag V4L2_SUBDEV_MBUS_CODE_CSC_COLORSPACE in the "
"corresponding struct :c:type:`v4l2_subdev_mbus_code_enum` during "
"enumeration. See :ref:`v4l2-subdev-mbus-code-flags`. Zero for metadata mbus "
"codes."
msgstr ""

