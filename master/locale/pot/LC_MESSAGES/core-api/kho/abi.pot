msgid "Main memblock node (/):"
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:41
msgid ""
"compatible: \"memblock-v1\" Identifies the overall memblock ABI version."
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:44
msgid "reserved_mem node:"
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:45
msgid ""
"These nodes describe all reserve_mem regions. The node name is the name "
"defined by the user for a reserve_mem region."
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:48
msgid "compatible: \"reserve-mem-v1\""
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:50
msgid "Identifies the ABI version of reserve_mem descriptions"
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:52
msgid "start: u64"
msgstr ""

#: ../../../core-api/kho/abi:22: ../include/linux/kho/abi/memblock.h:54
