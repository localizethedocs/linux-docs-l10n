msgid "Find the next gap in the page cache."
msgstr ""

#: ../../../core-api/mm-api:61: ../mm/filemap.c:1789 ../mm/filemap.c:1826
msgid "Mapping."
msgstr ""

#: ../../../core-api/mm-api:123: ../mm/shmem.c:2650 ../mm/shmem.c:5970
