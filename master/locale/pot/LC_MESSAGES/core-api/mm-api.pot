msgid "Below is a brief outline of the most useful GFP flags"
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:907
msgid "``GFP_KERNEL``"
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:908
msgid "Allocate normal kernel ram. May sleep."
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:910
msgid "``GFP_NOWAIT``"
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:911
msgid "Allocation will not sleep."
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:913
msgid "``GFP_ATOMIC``"
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:914
msgid "Allocation will not sleep.  May use emergency pools."
msgstr ""

#: ../../../core-api/mm-api:37: ../include/linux/slab.h:916
msgid ""
"Also it is possible to set different flags by OR'ing in one or more of the "
"following additional **flags**:"
