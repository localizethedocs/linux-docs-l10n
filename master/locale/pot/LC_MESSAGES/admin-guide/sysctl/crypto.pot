#: ../../../admin-guide/sysctl/crypto.rst:3
msgid "/proc/sys/crypto/"
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:5
msgid ""
"These files show up in ``/proc/sys/crypto/``, depending on the kernel "
"configuration:"
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:11
msgid "fips_enabled"
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:13
msgid "Read-only flag that indicates whether FIPS mode is enabled."
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:15
msgid "``0``: FIPS mode is disabled (default)."
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:16
msgid "``1``: FIPS mode is enabled."
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:18
msgid ""
"This value is set at boot time via the ``fips=1`` kernel command line "
"parameter. When enabled, the cryptographic API will restrict the use of "
"certain algorithms and perform self-tests to ensure compliance with FIPS "
"(Federal Information Processing Standards) requirements, such as FIPS 140-2 "
"and the newer FIPS 140-3, depending on the kernel configuration and the "
"module in use."
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:26
msgid "fips_name"
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:28
msgid ""
"Read-only file that contains the name of the FIPS module currently in use. "
"The value is typically configured via the ``CONFIG_CRYPTO_FIPS_NAME`` kernel "
"configuration option."
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:33
msgid "fips_version"
msgstr ""

#: ../../../admin-guide/sysctl/crypto.rst:35
msgid ""
"Read-only file that contains the version string of the FIPS module. If "
"``CONFIG_CRYPTO_FIPS_CUSTOM_VERSION`` is set, it uses the value from "
"``CONFIG_CRYPTO_FIPS_VERSION``. Otherwise, it defaults to the kernel release "
"version (``UTS_RELEASE``)."
msgstr ""

