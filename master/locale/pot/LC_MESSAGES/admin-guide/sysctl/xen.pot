msgid ""
"These files show up in ``/proc/sys/xen/``, depending on the kernel "
"configuration:"
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:18
msgid "balloon/hotplug_unpopulated"
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:20
msgid ""
"This flag controls whether unpopulated memory ranges are automatically "
"hotplugged as system RAM."
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:23
msgid "``0``: Unpopulated ranges are not hotplugged (default)."
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:24
msgid "``1``: Unpopulated ranges are automatically hotplugged."
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:26
msgid ""
"When enabled, the Xen balloon driver will add memory regions that are marked "
"as unpopulated in the Xen memory map to the system as usable RAM. This "
"allows for dynamic memory expansion in Xen guest domains."
msgstr ""

#: ../../../admin-guide/sysctl/xen.rst:30
msgid ""
"This option is only available when the kernel is built with "
"``CONFIG_XEN_BALLOON_MEMORY_HOTPLUG`` enabled."
msgstr ""
