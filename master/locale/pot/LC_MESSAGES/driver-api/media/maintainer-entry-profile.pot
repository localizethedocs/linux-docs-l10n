#: ../../../driver-api/media/maintainer-entry-profile.rst:260
msgid ""
"See https://www.kernel.org/category/releases.html for an overview about "
"Kernel release types."
msgstr ""

#: ../../../driver-api/media/maintainer-entry-profile.rst:263
msgid "Patches with fixes shall have:"
msgstr ""

#: ../../../driver-api/media/maintainer-entry-profile.rst:265
msgid "a ``Fixes:`` tag pointing to the first commit that introduced the bug;"
