#: ../../../driver-api/80211/mac80211:32: ../include/net/mac80211.h:3123
msgid "``extra_beacon_tailroom``"
msgstr ""

#: ../../../driver-api/80211/mac80211:32: ../include/net/mac80211.h:3124
