#: ../../../driver-api/80211/mac80211:109: ../include/net/mac80211.h:995
msgid "``IEEE80211_TX_STAT_AMPDU``"
msgstr ""

#: ../../../driver-api/80211/mac80211:109: ../include/net/mac80211.h:996
