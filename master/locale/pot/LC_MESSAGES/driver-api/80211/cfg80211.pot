"EAP re-authentication protocol (ERP) realm part of NAI or ``NULL`` if not "
"specified. This specifies the domain name of ER server and is used to "
"construct FILS wrapped data IE."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3572
msgid "``fils_erp_realm_len``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3573
msgid "Length of **fils_erp_realm** in octets."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3573
msgid "``fils_erp_next_seq_num``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3574
msgid ""
"The next sequence number to use in the FILS ERP messages. This is also used "
"to construct FILS wrapped data IE."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3575
msgid "``fils_erp_rrk``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3576
msgid ""
"ERP re-authentication Root Key (rRK) used to derive additional keys in FILS "
"or ``NULL`` if not specified."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3577
msgid "``fils_erp_rrk_len``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:3578
msgid "Length of **fils_erp_rrk** in octets."
msgstr ""

