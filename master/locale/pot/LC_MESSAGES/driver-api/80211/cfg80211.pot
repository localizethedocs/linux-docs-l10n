msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4755
msgid "get a mesh proxy path for the given parameters"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4755
msgid "``dump_mpp``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4756
msgid "dump mesh proxy path callback -- resume dump at index **idx**"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4761
msgid "``get_mesh_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4762
msgid "Get the current mesh configuration"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4763
msgid "``update_mesh_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4764
msgid ""
"Update mesh parameters on a running mesh. The mask is a bitfield which tells "
"us which parameters to set, and which to leave alone."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4756
msgid "``join_mesh``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4757
msgid ""
"join the mesh network with the specified parameters (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4758
msgid "``leave_mesh``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4759
msgid ""
"leave the current mesh network (invoked with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4983
msgid "``join_ocb``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4984
msgid ""
"join the OCB network with the specified parameters (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4985
msgid "``leave_ocb``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4986
msgid ""
"leave the current OCB network (invoked with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4767
msgid "``change_bss``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4768
msgid "Modify parameters for a given BSS."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4769
msgid "``inform_bss``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4770
msgid ""
"Called by cfg80211 while being informed about new BSS data for every BSS "
"found within the reported data or frame. This is called from within the "
"cfg8011 inform_bss handlers while holding the bss_lock. The data parameter "
"is passed through from drv_data inside struct cfg80211_inform_bss. The new "
"IE data for the BSS is explicitly passed."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4776
msgid "``set_txq_params``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4777
msgid "Set TX queue parameters"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4778
msgid "``libertas_set_mesh_channel``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4779
msgid ""
"Only for backward compatibility for libertas, as it doesn't implement "
"join_mesh and needs to set the channel to join the mesh instead."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4782
msgid "``set_monitor_channel``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4783
msgid ""
"Set the monitor mode channel for the device. If other interfaces are active "
"this callback should reject the configuration. If no interfaces are active "
"or the device is down, the channel should be stored for when a monitor "
"interface becomes active."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4787
msgid "``scan``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4788
msgid ""
"Request to do a scan. If returning zero, the scan request is given the "
"driver, and will be valid until passed to cfg80211_scan_done(). For scan "
"results, call cfg80211_inform_bss(); you can call this outside the scan/"
"scan_done bracket too."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4791
msgid "``abort_scan``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4792
msgid ""
"Tell the driver to abort an ongoing scan. The driver shall indicate the "
"status of the scan through cfg80211_scan_done()."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4794
msgid "``auth``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4795
msgid ""
"Request to authenticate with the specified peer (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4796
msgid "``assoc``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4797
msgid ""
"Request to (re)associate with the specified peer (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4798
msgid "``deauth``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4799
msgid ""
"Request to deauthenticate from the specified peer (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4800
msgid "``disassoc``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4801
msgid ""
"Request to disassociate from the specified peer (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4803
msgid "``connect``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4804
msgid ""
"Connect to the ESS with the specified parameters. When connected, call "
"cfg80211_connect_result()/cfg80211_connect_bss() with status code "
"``WLAN_STATUS_SUCCESS``. If the connection fails for some reason, call "
"cfg80211_connect_result()/cfg80211_connect_bss() with the status code from "
"the AP or cfg80211_connect_timeout() if no frame with status code was "
"received. The driver is allowed to roam to other BSSes within the ESS when "
"the other BSS matches the connect parameters. When such roaming is initiated "
"by the driver, the driver is expected to verify that the target matches the "
"configured security parameters and to use Reassociation Request frame "
"instead of Association Request frame. The connect function can also be used "
"to request the driver to perform a specific roam when connected to an ESS. "
"In that case, the prev_bssid parameter is set to the BSSID of the currently "
"associated BSS as an indication of requesting reassociation. In both the "
"driver-initiated and new connect() call initiated roaming cases, the result "
"of roaming is indicated with a call to cfg80211_roamed(). (invoked with the "
"wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4821
msgid "``update_connect_params``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4822
msgid ""
"Update the connect parameters while connected to a BSS. The updated "
"parameters can be used by driver/firmware for subsequent BSS selection "
"(roaming) decisions and to form the Authentication/(Re)Association Request "
"frames. This call does not request an immediate disassociation or "
"reassociation with the current BSS, i.e., this impacts only subsequent "
"(re)associations. The bits in changed are defined in :c:type:`enum "
"cfg80211_connect_params_changed <cfg80211_connect_params_changed>`. (invoked "
"with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4829
msgid "``disconnect``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4830
msgid ""
"Disconnect from the BSS/ESS or stop connection attempts if connection is in "
"progress. Once done, call cfg80211_disconnected() in case connection was "
"already established (invoked with the wireless_dev mutex held), otherwise "
"call cfg80211_connect_timeout()."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4834
msgid "``join_ibss``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4835
msgid ""
"Join the specified IBSS (or create if necessary). Once done, call "
"cfg80211_ibss_joined(), also call that function when changing BSSID due to a "
"merge. (invoked with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4838
msgid "``leave_ibss``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4839
msgid "Leave the IBSS. (invoked with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4841
msgid "``set_mcast_rate``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4842
msgid "Set the specified multicast rate (only if vif is in ADHOC or MESH mode)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4844
msgid "``set_wiphy_params``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4845
msgid ""
"Notify that wiphy parameters have changed; **changed** bitfield (see :c:type:"
"`enum wiphy_params_flags <wiphy_params_flags>`) describes which values have "
"changed. The actual parameter values are available in struct wiphy. If "
"returning an error, no value should be changed."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4849
msgid "``set_tx_power``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4850
msgid ""
"set the transmit power according to the parameters, the power passed is in "
"mBm, to get dBm use MBM_TO_DBM(). The wdev may be ``NULL`` if power was set "
"for the wiphy, and will always be ``NULL`` unless the driver supports per-"
"vif TX power (as advertised by the nl80211 feature flag.)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4854
msgid "``get_tx_power``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4855
msgid ""
"store the current TX power into the dbm variable; return 0 if successful"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4857
msgid "``rfkill_poll``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4858
msgid ""
"polls the hw rfkill line, use cfg80211 reporting functions to adjust rfkill "
"hw state"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4874
msgid "``testmode_cmd``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4875
msgid "run a test mode command; **wdev** may be ``NULL``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4875
msgid "``testmode_dump``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4876
msgid ""
"Implement a test mode dump. The cb->args[2] and up may be used by the "
"function, but 0 and 1 must not be touched. Additionally, return error codes "
"other than -ENOBUFS and -ENOENT will terminate the dump and return to "
"userspace with an error, so be careful. If any data was passed in from "
"userspace then the data/len arguments will be present and point to the data "
"contained in ``NL80211_ATTR_TESTDATA``."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4882
msgid "``set_bitrate_mask``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4883
msgid "set the bitrate mask configuration"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4860
msgid "``dump_survey``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4861
msgid "get site survey information."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4884
msgid "``set_pmksa``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4885
msgid ""
"Cache a PMKID for a BSSID. This is mostly useful for fullmac devices running "
"firmwares capable of generating the (re) association RSN IE. It allows for "
"faster roaming between WPA2 BSSIDs."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4887
msgid "``del_pmksa``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4888
msgid "Delete a cached PMKID."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4888
msgid "``flush_pmksa``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4889
msgid "Flush all cached PMKIDs."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4862
msgid "``remain_on_channel``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4863
msgid ""
"Request the driver to remain awake on the specified channel for the "
"specified duration to complete an off-channel operation (e.g., public action "
"frame exchange). When the driver is ready on the requested channel, it must "
"indicate this with an event notification by calling "
"cfg80211_ready_on_channel()."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4867
msgid "``cancel_remain_on_channel``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4868
msgid ""
"Cancel an on-going remain-on-channel operation. This allows the operation to "
"be terminated prior to timeout based on the duration value."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4870
msgid "``mgmt_tx``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4871
msgid "Transmit a management frame."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4871
msgid "``mgmt_tx_cancel_wait``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4872
msgid ""
"Cancel the wait time from transmitting a management frame on another channel"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4889
msgid "``set_power_mgmt``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4890
msgid ""
"Configure WLAN power management. A timeout value of -1 allows the driver to "
"adjust the dynamic ps timeout value."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4891
msgid "``set_cqm_rssi_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4892
msgid ""
"Configure connection quality monitor RSSI threshold. After configuration, "
"the driver should (soon) send an event indicating the current level is above/"
"below the configured threshold; this may need some care when the "
"configuration is changed (without first being disabled.)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4896
msgid "``set_cqm_rssi_range_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4897
msgid ""
"Configure two RSSI thresholds in the connection quality monitor.  An event "
"is to be sent only when the signal level is found to be outside the two "
"values.  The driver should set ``NL80211_EXT_FEATURE_CQM_RSSI_LIST`` if this "
"method is implemented. If it is provided then there's no point providing "
"**set_cqm_rssi_config**."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4901
msgid "``set_cqm_txe_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4902
msgid "Configure connection quality monitor TX error thresholds."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4911
msgid "``update_mgmt_frame_registrations``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4912
msgid ""
"Notify the driver that management frame registrations were updated. The "
"callback is allowed to sleep."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4914
msgid "``set_antenna``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4915
msgid ""
"Set antenna configuration (tx_ant, rx_ant) on the device. Parameters are "
"bitmaps of allowed antennas to use for TX/RX. Drivers may reject TX/RX mask "
"combinations they cannot support by returning -EINVAL (also see nl80211.h "
"**NL80211_ATTR_WIPHY_ANTENNA_TX**)."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4919
msgid "``get_antenna``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4920
msgid "Get current antenna configuration from device (tx_ant, rx_ant)."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4903
msgid "``sched_scan_start``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4904
msgid "Tell the driver to start a scheduled scan."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4904
msgid "``sched_scan_stop``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4905
msgid ""
"Tell the driver to stop an ongoing scheduled scan with given request id. "
"This call must stop the scheduled scan and be ready for starting a new one "
"before it returns, i.e. **sched_scan_start** may be called immediately after "
"that again and should not fail in that case. The driver should not call "
"cfg80211_sched_scan_stopped() for a requested stop (when this method returns "
"0)."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4732
msgid "``set_rekey_data``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4733
msgid "give the data necessary for GTK rekeying to the driver"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4921
msgid "``tdls_mgmt``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4922
msgid "Transmit a TDLS management frame."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4922
msgid "``tdls_oper``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4923
msgid "Perform a high-level TDLS operation (e.g. TDLS link setup)."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4924
msgid "``probe_client``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4925
msgid ""
"probe an associated client, must return a cookie that it later passes to "
"cfg80211_probe_status()."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4927
msgid "``set_noack_map``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4928
msgid "Set the NoAck Map for the TIDs."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4929
msgid "``get_channel``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4930
msgid ""
"Get the current operating channel for the virtual interface. For monitor "
"interfaces, it should return ``NULL`` unless there's a single current "
"monitoring channel."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4933
msgid "``start_p2p_device``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4934
msgid "Start the given P2P device."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4934
msgid "``stop_p2p_device``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4935
msgid "Stop the given P2P device."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4936
msgid "``set_mac_acl``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4937
msgid ""
"Sets MAC address control list in AP and P2P GO mode. Parameters include ACL "
"policy, an array of MAC address of stations and the number of MAC addresses. "
"If there is already a list in driver this new list replaces the existing "
"one. Driver has to clear its ACL when number of MAC addresses entries is "
"passed as 0. Drivers which advertise the support for MAC based ACL have to "
"implement this callback."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4943
msgid "``start_radar_detection``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4944
msgid "Start radar detection in the driver."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4945
msgid "``end_cac``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4946
msgid ""
"End running CAC, probably because a related CAC was finished on another phy."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4948
msgid "``update_ft_ies``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4949
msgid ""
"Provide updated Fast BSS Transition information to the driver. If the SME is "
"in the driver/firmware, this information can be used in building "
"Authentication and Reassociation Request frames."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4952
msgid "``crit_proto_start``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4953
msgid ""
"Indicates a critical protocol needs more link reliability for a given "
"duration (milliseconds). The protocol is provided so the driver can take the "
"most appropriate actions."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4955
msgid "``crit_proto_stop``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4956
msgid ""
"Indicates critical protocol no longer needs increased link reliability. This "
"operation can not fail."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4957
msgid "``set_coalesce``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4958
msgid "Set coalesce parameters."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4959
msgid "``channel_switch``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4960
msgid ""
"initiate channel-switch procedure (with CSA). Driver is responsible for "
"veryfing if the switch is possible. Since this is inherently tricky driver "
"may decide to disconnect an interface later with cfg80211_stop_iface(). This "
"doesn't mean driver can accept everything. It should do it's best to verify "
"requests and reject them as soon as possible."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4966
msgid "``set_qos_map``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4967
msgid "Set QoS mapping information to the driver"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4968
msgid "``set_ap_chanwidth``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4969
msgid ""
"Set the AP (including P2P GO) mode channel width for the given interface "
"This is used e.g. for dynamic HT 20/40 MHz channel width changes during the "
"lifetime of the BSS."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4972
msgid "``add_tx_ts``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4973
msgid ""
"validate (if admitted_time is 0) or add a TX TS to the device with the given "
"parameters; action frame exchange has been handled by userspace so this just "
"has to modify the TX path to take the TS into account. If the admitted time "
"is 0 just validate the parameters to make sure the session can be created at "
"all; it is valid to just always return success for that but that may result "
"in inefficient behaviour (handshake with the peer followed by immediate "
"teardown when the addition is later rejected)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4981
msgid "``del_tx_ts``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4982
msgid "remove an existing TX TS"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4988
msgid "``tdls_channel_switch``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4989
msgid ""
"Start channel-switching with a TDLS peer. The driver is responsible for "
"continually initiating channel-switching operations and returning to the "
"base channel for communication with the AP."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4991
msgid "``tdls_cancel_channel_switch``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4992
msgid ""
"Stop channel-switching with a TDLS peer. Both peers must be on the base "
"channel when the call completes."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4993
msgid "``start_nan``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4994
msgid "Start the NAN interface."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4994
msgid "``stop_nan``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4995
msgid "Stop the NAN interface."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4995
msgid "``add_nan_func``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4996
msgid ""
"Add a NAN function. Returns negative value on failure. On success "
"**nan_func** ownership is transferred to the driver and it may access it "
"outside of the scope of this function. The driver should free the "
"**nan_func** when no longer needed by calling cfg80211_free_nan_func(). On "
"success the driver should assign an instance_id in the provided **nan_func**."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5002
msgid "``del_nan_func``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5003
msgid "Delete a NAN function."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5003
msgid "``nan_change_conf``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5004
msgid ""
"changes NAN configuration. The changed parameters must be specified in "
"**changes** (using :c:type:`enum cfg80211_nan_conf_changes "
"<cfg80211_nan_conf_changes>`); All other parameters must be ignored."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5006
msgid "``nan_set_local_sched``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5007
msgid ""
"configure the local schedule for NAN. The schedule consists of an array of "
"``cfg80211_nan_channel`` and the schedule itself, in which each entry maps "
"each time slot to the channel on which the radio should operate on. If the "
"chandef of a NAN channel is not changed, the channel entry must also remain "
"unchanged. It is the driver's responsibility to verify this."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5012
msgid "``nan_set_peer_sched``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5013
msgid ""
"configure the peer schedule for NAN. The schedule consists of an array of "
"``cfg80211_nan_channel`` and the schedule itself, in which each entry maps "
"each time slot to a channel on which the radio should operate on. In "
"addition, it contains more peer's schedule information such as committed DW, "
"etc. When updating an existing peer schedule, the full new schedule is "
"provided - partial updates are not supported, and the new schedule "
"completely replaces the previous one."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5020
msgid "``set_multicast_to_unicast``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5021
msgid "configure multicast to unicast conversion for BSS"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5022
msgid "``get_txq_stats``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5023
msgid ""
"Get TXQ stats for interface or phy. If wdev is ``NULL``, this function "
"should return phy stats, and interface stats otherwise."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5025
msgid "``set_pmk``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5026
msgid ""
"configure the PMK to be used for offloaded 802.1X 4-Way handshake. If not "
"deleted through **del_pmk** the PMK remains valid until disconnect upon "
"which the driver should clear it. (invoked with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5029
msgid "``del_pmk``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5030
msgid ""
"delete the previously configured PMK for the given authenticator. (invoked "
"with the wireless_dev mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5032
msgid "``external_auth``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5033
msgid "indicates result of offloaded authentication processing from user space"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5035
msgid "``tx_control_port``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5036
msgid ""
"TX a control port frame (EAPoL).  The noencrypt parameter tells the driver "
"that the frame should not be encrypted."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5038
msgid "``get_ftm_responder_stats``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5039
msgid ""
"Retrieve FTM responder statistics, if available. Statistics should be "
"cumulative, currently no way to reset is provided."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5040
msgid "``start_pmsr``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5041
msgid "start peer measurement (e.g. FTM)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5041
msgid "``abort_pmsr``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5042
msgid "abort peer measurement"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5043
msgid "``update_owe_info``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5044
msgid ""
"Provide updated OWE info to driver. Driver implementing SME but offloading "
"OWE processing to the user space will get the updated DH IE through this "
"interface."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5047
msgid "``probe_mesh_link``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5048
msgid ""
"Probe direct Mesh peer's link quality by sending data frame and overrule "
"HWMP path selection algorithm."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5049
msgid "``set_tid_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5050
msgid ""
"TID specific configuration, this can be peer or BSS specific This callback "
"may sleep."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5051
msgid "``reset_tid_config``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5052
msgid ""
"Reset TID specific configuration for the peer, for the given TIDs. This "
"callback may sleep."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5054
msgid "``set_sar_specs``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5055
msgid "Update the SAR (TX power) settings."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5056
msgid "``color_change``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5057
msgid "Initiate a color change."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5058
msgid "``set_fils_aad``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5059
msgid ""
"Set FILS AAD data to the AP driver so that the driver can use those to "
"decrypt (Re)Association Request and encrypt (Re)Association Response frame."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5062
msgid "``set_radar_background``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5063
msgid ""
"Configure dedicated offchannel chain available for radar/CAC detection on "
"some hw. This chain can't be used to transmit or receive frames and it is "
"bounded to a running wdev. Background radar/CAC detection allows to avoid "
"the CAC downtime switching to a different channel during CAC detection on "
"the selected radar channel. The caller is expected to set chandef pointer to "
"NULL in order to disable background CAC/radar detection."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5070
msgid "``add_link_station``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5071
msgid "Add a link to a station."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5071
msgid "``mod_link_station``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5072
msgid "Modify a link of a station."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5072
msgid "``del_link_station``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5073
msgid "Remove a link of a station."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5074
msgid "``set_hw_timestamp``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5075
msgid "Enable/disable HW timestamping of TM/FTM frames."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5075
msgid "``set_ttlm``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5076
msgid "set the TID to link mapping."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5077
msgid "``get_radio_mask``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5078
msgid "get bitmask of radios in use. (invoked with the wiphy mutex held)"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5079
msgid "``assoc_ml_reconf``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5080
msgid ""
"Request a non-AP MLO connection to perform ML reconfiguration, i.e., add and/"
"or remove links to/from the association using ML reconfiguration action "
"frames. Successfully added links will be added to the set of valid links. "
"Successfully removed links will be removed from the set of valid links. The "
"driver must indicate removed links by calling cfg80211_links_removed() and "
"added links by calling cfg80211_mlo_reconf_add_done(). When calling "
"cfg80211_mlo_reconf_add_done() the bss pointer must be given for each link "
"for which MLO reconfiguration 'add' operation was requested."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5076
msgid "``set_epcs``"
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:5077
msgid "Enable/Disable EPCS for station mode."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4664
msgid ""
"This struct is registered by fullmac card drivers and/or wireless stacks in "
"order to handle configuration requests on their interfaces."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4667
msgid ""
"All callbacks except where otherwise noted should return 0 on success or a "
"negative error code."
msgstr ""

#: ../../../driver-api/80211/cfg80211:48: ../include/net/cfg80211.h:4670
msgid ""
"All operations are invoked with the wiphy mutex held. The RTNL may be held "
"in addition (due to wireless extensions) but this cannot be relied upon "
"except in cases where documented below. Note that due to ordering, the RTNL "
"also cannot be acquired in any handlers."
msgstr ""

