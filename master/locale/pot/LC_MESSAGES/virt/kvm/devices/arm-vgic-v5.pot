#: ../../../virt/kvm/devices/arm-vgic-v5.rst:5
msgid "ARM Virtual Generic Interrupt Controller v5 (VGICv5)"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:8
msgid "Device types supported:"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:9
msgid "KVM_DEV_TYPE_ARM_VGIC_V5     ARM Generic Interrupt Controller v5.0"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:11
msgid ""
"Only one VGIC instance may be instantiated through this API.  The created "
"VGIC will act as the VM interrupt controller, requiring emulated user-space "
"devices to inject interrupts to the VGIC instead of directly to CPUs."
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:15
msgid ""
"Creating a guest GICv5 device requires a host GICv5 host.  The current "
"VGICv5 device only supports PPI interrupts.  These can either be injected "
"from emulated in-kernel devices (such as the Arch Timer, or PMU), or via the "
"KVM_IRQ_LINE ioctl."
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:20
msgid "Groups:"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:21
msgid "KVM_DEV_ARM_VGIC_GRP_CTRL"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:22
msgid "Attributes:"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:24
msgid "KVM_DEV_ARM_VGIC_CTRL_INIT"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:25
msgid ""
"request the initialization of the VGIC, no additional parameter in "
"kvm_device_attr.addr. Must be called after all VCPUs have been created."
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:28
msgid "KVM_DEV_ARM_VGIC_USERPSPACE_PPIs"
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:29
msgid ""
"request the mask of userspace-drivable PPIs. Only a subset of the PPIs can "
"be directly driven from userspace with GICv5, and the returned mask informs "
"userspace of which it is allowed to drive via KVM_IRQ_LINE."
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:33
msgid ""
"Userspace must allocate and point to __u64[2] of data in kvm_device_attr."
"addr. When this call returns, the provided memory will be populated with the "
"userspace PPI mask. The lower __u64 contains the mask for the lower 64 PPIS, "
"with the remaining 64 being in the second __u64."
msgstr ""

#: ../../../virt/kvm/devices/arm-vgic-v5.rst:38
msgid ""
"This is a read-only attribute, and cannot be set. Attempts to set it are "
"rejected."
msgstr ""

