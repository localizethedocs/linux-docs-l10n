"SYNC signal embedded into its base clock frequency."
msgstr ""

#: ../../../netlink/specs/dpll.yaml:443
msgid "esync-frequency-supported (``nest``)"
msgstr ""

#: ../../../netlink/specs/dpll.yaml:443
msgid ""
