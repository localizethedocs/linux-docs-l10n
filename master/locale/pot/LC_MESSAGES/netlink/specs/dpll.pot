msgstr ""

#: ../../../netlink/specs/dpll.yaml:465
msgid "phase-adjust-gran (``u32``)"
msgstr ""

#: ../../../netlink/specs/dpll.yaml:465
msgid ""
"Granularity of phase adjustment, in picoseconds. The value of phase "
"adjustment must be a multiple of this granularity."
msgstr ""

#: ../../../netlink/specs/dpll.yaml:471
msgid "fractional-frequency-offset-ppt (``sint``)"
msgstr ""

#: ../../../netlink/specs/dpll.yaml:471
msgid ""
"The FFO (Fractional Frequency Offset) of the pin with respect to the nominal "
"frequency. Value = (frequency_measured - frequency_nominal) / "
"frequency_nominal Value is in PPT (parts per trillion, 10^-12). Note: This "
"attribute provides higher resolution than the standard fractional-frequency-"
"offset (which is in PPM)."
msgstr ""

#: ../../../netlink/specs/dpll.yaml:481
msgid "measured-frequency (``u64``)"
msgstr ""

#: ../../../netlink/specs/dpll.yaml:481
msgid ""
"The measured frequency of the input pin in millihertz (mHz). Value of "
"(DPLL_A_PIN_MEASURED_FREQUENCY / DPLL_PIN_MEASURED_FREQUENCY_DIVIDER) is an "
"integer part (Hz) of a measured frequency value. Value of "
"(DPLL_A_PIN_MEASURED_FREQUENCY % DPLL_PIN_MEASURED_FREQUENCY_DIVIDER) is a "
"fractional part of a measured frequency value."
msgstr ""

